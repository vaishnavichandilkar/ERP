generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(uuid())
  first_name            String?
  last_name             String?
  email                 String?                @unique
  phone                 String?                @unique
  selected_language     String?
  role                  Role                   @default(buyer)
  refresh_token         String?
  onboarded_at          DateTime?
  verified              Boolean                @default(false)
  isApproved            Boolean                @default(false)
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  deleted_at            DateTime?
  isBlocked             Boolean                @default(false)
  approvalStatus        ApprovalStatus         @default(PENDING)
  rejectionReason       String?
  isFirstApprovalLogin  Boolean                @default(true)
  bankDetail            BankDetail?
  sellerDocuments       SellerDocument[]       @relation("UploadedByUser")
  shopDetail            ShopDetail?
  weighingMachineDetail WeighingMachineDetail?
  facilities            Facility[]             @relation("SellerFacilities")
  otpVerifications      OtpVerification[]

  @@map("User")
}

model BankDetail {
  id         String   @id @default(uuid())
  userId     String   @unique
  holderName String
  accountNo  String   @unique
  ifsc       String
  bankName   String
  panNumber  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("BankDetail")
}

model ShopDetail {
  id        String   @id @default(uuid())
  userId    String   @unique
  shopName  String
  address   String
  village   String?
  pinCode   String
  state     String
  district  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ShopDetail")
}

model WeighingMachineDetail {
  id                String   @id @default(uuid())
  userId            String   @unique
  isUsingOwnMachine Boolean
  make              String?
  machineName       String
  modelNumber       String?
  machineType       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("WeighingMachineDetail")
}

model Otp {
  id         Int      @id @default(autoincrement())
  phone      String   @unique
  otp        String
  expiresAt  DateTime
  isVerified Boolean  @default(false)

  @@map("Otp")
}

model SellerDocument {
  id               Int                @id @default(autoincrement())
  profileId        Int?
  type             SellerDocumentType
  url              String
  category         String?
  uploadedByUserId String?
  name             String?
  size             BigInt             @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  uploadedByUser   User?              @relation("UploadedByUser", fields: [uploadedByUserId], references: [id])

  @@map("SellerDocument")
}

model Facility {
  id             String          @id @default(uuid())
  name           String          @db.VarChar(150)
  location       String          @db.VarChar(150)
  address        String
  totalMachines  Int
  gstNumber      String?         @db.VarChar(15)
  status         FacilityStatus  @default(ACTIVE)
  isDeleted      Boolean         @default(false)
  sellerId       String          @default("legacy")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  administrators Administrator[]
  seller         User            @relation("SellerFacilities", fields: [sellerId], references: [id])
  operators      Operator[]

  @@map("facilities")
}

model Administrator {
  id          String                    @id @default(uuid())
  name        String
  username    String                    @unique
  mobile      String?
  facilityId  String
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  permissions AdministratorPermission[]
  facility    Facility                  @relation(fields: [facilityId], references: [id])

  @@map("administrators")
}

model Operator {
  id          String               @id @default(uuid())
  name        String
  username    String               @unique
  mobile      String?
  facilityId  String
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  permissions OperatorPermission[]
  facility    Facility             @relation(fields: [facilityId], references: [id])

  @@map("operators")
}

model Module {
  id                       String                    @id @default(uuid())
  name                     String                    @unique
  administratorPermissions AdministratorPermission[]
  operatorPermissions      OperatorPermission[]

  @@map("modules")
}

model AdministratorPermission {
  id              String        @id @default(uuid())
  administratorId String
  moduleId        String
  canView         Boolean       @default(false)
  canCreate       Boolean       @default(false)
  canUpdate       Boolean       @default(false)
  canDelete       Boolean       @default(false)
  administrator   Administrator @relation(fields: [administratorId], references: [id], onDelete: Cascade)
  module          Module        @relation(fields: [moduleId], references: [id])

  @@unique([administratorId, moduleId])
  @@map("administrator_permissions")
}

model OtpVerification {
  id        String   @id @default(uuid())
  userId    String
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

model OperatorPermission {
  id         String   @id @default(uuid())
  operatorId String
  moduleId   String
  canView    Boolean  @default(false)
  canCreate  Boolean  @default(false)
  canUpdate  Boolean  @default(false)
  canDelete  Boolean  @default(false)
  module     Module   @relation(fields: [moduleId], references: [id])
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([operatorId, moduleId])
  @@map("operator_permissions")
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  userType         String
  jti              String   @unique
  refreshTokenHash String
  expiresAt        DateTime
  isRevoked        Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String
  ip        String?
  userAgent String?
  details   Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model SellerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  currentStep     Int      @default(0)
  status          String   @default("IN_PROGRESS") 
  sessionId       String   @unique
  addressId       String?
  bankDetailId    String?
  sellerId        String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  approvedAt      DateTime?
  onHoldUntil     DateTime?
  rejectionReason String?

  reviews         SellerStepReview[]
  @@map("SellerProfile")
}

model SellerStepReview {
  id              String   @id @default(uuid())
  sellerProfileId String
  step            Int
  status          String   @default("PENDING")
  data            Json?
  remark          String?
  reviewedBy      String?
  reviewedAt      DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@unique([sellerProfileId, step])
  @@map("SellerStepReview")
}

model Pincode {
  id        String   @id @default(uuid())
  pincode   String   @unique
  state     String
  district  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Pincode")
}

enum AdminStatus {
  PENDING_OTP
  PENDING_PROFILE
  PENDING_APPROVAL
  ACTIVE
  REJECTED
}

enum Role {
  buyer
  seller
  superadmin
  administrator
  operator
}

enum SellerDocumentType {
  PAN
  GST
  AADHAR
  BANK
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
}
