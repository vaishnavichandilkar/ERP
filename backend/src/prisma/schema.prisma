generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// System Admin (for bootstrapping and global management)
enum AdminStatus {
  PENDING_OTP
  PENDING_PROFILE
  PENDING_APPROVAL
  ACTIVE
  REJECTED
}
// ENUMS

enum Role {
  buyer
  seller

  // COMPANY PANEL ROLES
  superadmin
  administrator
  operator
}

enum SellerDocumentType {
  PAN
  GST
  AADHAR
  BANK
  OTHER
}



// USER MODEL

model User {
  id                 String    @id @default(uuid())

  first_name         String?
  last_name          String?

  email              String?   @unique
  phone              String?   @unique

  selected_language  String?

  role               Role      @default(buyer)

  password           String?

  refresh_token      String?

  onboarded_at       DateTime?
  isApproved         Boolean   @default(false)

  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  deleted_at         DateTime?

  isBlocked          Boolean   @default(false)


  // RELATIONS
  sellerDocuments    SellerDocument[] @relation("UploadedByUser")
  bankDetail         BankDetail?
  shopDetail         ShopDetail?
  otpVerifications   OtpVerification[]
  facilities         Facility[]       @relation("SellerFacilities")

  @@map("User")
}




// BANK DETAIL MODEL
model BankDetail {
  id          String    @id @default(uuid())
  userId      String    @unique
  holderName  String
  accountNo   String    @unique
  ifsc        String
  bankName    String
  panNumber   String?   // New field
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("BankDetail")
}

// SHOP DETAIL MODEL (Suggested Improvement for Step 4)
model ShopDetail {
  id          String   @id @default(uuid())
  userId      String   @unique
  shopName    String
  address     String
  village     String?
  pinCode     String
  state       String
  district    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ShopDetail")
}




// OTP MODEL

model Otp {

  id         Int      @id @default(autoincrement())

  phone      String   @unique

  otp        String

  expiresAt  DateTime


  @@map("Otp")

}




// SELLER DOCUMENT MODEL

model SellerDocument {
  id                Int      @id @default(autoincrement())
  profileId         Int?
  type              SellerDocumentType
  url               String
  category          String?
  uploadedByUserId  String?

  name              String?
  size              BigInt   @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt


  // RELATION WITH USER
  uploadedByUser User? @relation("UploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("SellerDocument")
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
}

model Facility {
  id            String         @id @default(uuid())
  name          String         @db.VarChar(150)
  location      String         @db.VarChar(150)
  address       String
  totalMachines Int
  gstNumber     String?        @db.VarChar(15)
  status        FacilityStatus @default(ACTIVE)
  isDeleted     Boolean        @default(false)
  
  sellerId      String         @default("legacy") // Temporary default to avoid migration issues if data exists, but we'll prune it.
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  seller        User           @relation("SellerFacilities", fields: [sellerId], references: [id])
  administrators Administrator[]
  operators      Operator[]

  @@map("facilities")
}

model Administrator {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String?
  mobile       String?
  facilityId   String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  facility     Facility @relation(fields: [facilityId], references: [id])
  permissions  AdministratorPermission[]

  @@map("administrators")
}

model Operator {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String?
  mobile       String?
  facilityId   String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  facility     Facility @relation(fields: [facilityId], references: [id])
  permissions  OperatorPermission[]

  @@map("operators")
}

model Module {
  id                     String                    @id @default(uuid())
  name                   String                    @unique // Dashboard, Users, Facilities, Reports, Billing, Settings
  administratorPermissions AdministratorPermission[]
  operatorPermissions    OperatorPermission[]

  @@map("modules")
}

model AdministratorPermission {
  id              String        @id @default(uuid())
  administratorId String
  moduleId        String
  canView         Boolean       @default(false)
  canCreate       Boolean       @default(false)
  canUpdate       Boolean       @default(false)
  canDelete       Boolean       @default(false)

  administrator   Administrator @relation(fields: [administratorId], references: [id], onDelete: Cascade)
  module          Module        @relation(fields: [moduleId], references: [id])

  @@unique([administratorId, moduleId])
  @@map("administrator_permissions")
}

model OtpVerification {
  id        String   @id @default(uuid())
  userId    String
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

model OperatorPermission {
  id          String   @id @default(uuid())
  operatorId  String
  moduleId    String
  canView     Boolean  @default(false)
  canCreate   Boolean  @default(false)
  canUpdate   Boolean  @default(false)
  canDelete   Boolean  @default(false)

  operator    Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  module      Module   @relation(fields: [moduleId], references: [id])

  @@unique([operatorId, moduleId])
  @@map("operator_permissions")
}



// Redefining UserSession without direct FK to support multiple tables
model Session {
  id               String   @id @default(uuid())
  userId           String   // UUID from any User table
  userType         String   // ADMIN, ADMINISTRATOR, OPERATOR
  jti              String   @unique
  refreshTokenHash String
  expiresAt        DateTime
  isRevoked        Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@map("sessions")
}


model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String
  ip        String?
  userAgent String?
  details   Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
