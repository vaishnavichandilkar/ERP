generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                    @id @default(autoincrement())
  first_name            String?
  last_name             String?
  email                 String?                @unique
  phone                 String?                @unique
  username              String?                @unique
  selected_language     String?
  role                  Role                   @default(buyer)
  refresh_token         String?
  onboarded_at          DateTime?
  verified              Boolean                @default(false)
  isApproved            Boolean                @default(false)
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  deleted_at            DateTime?
  isBlocked             Boolean                @default(false)
  approvalStatus        ApprovalStatus         @default(PENDING)
  rejectionReason       String?
  isFirstApprovalLogin  Boolean                @default(true)
  bankDetail            BankDetail?
  sellerDocuments       SellerDocument[]       @relation("UploadedByUser")
  shopDetail            ShopDetail?
  groups                Group[]
  subGroups             SubGroup[]
  subSubGroups          SubSubGroup[]
  subSubSubGroups       SubSubSubGroup[]
  subSubSubSubGroups    SubSubSubSubGroup[]

   units                 UnitMaster[]
  categories            Category[]
  subCategories         SubCategory[]
  products              Product[]
  accounts              AccountMaster[]
  @@map("User")
}

model UserProfile {
  id            Int      @id @default(autoincrement())
  phone_number  String   @unique
  name          String?
  email         String?
  profile_image String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("user_profiles")
}

model ShopDetail {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  shopName  String
  address   String
  village   String?
  pinCode   String
  state     String
  district  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ShopDetail")
}

model BankDetail {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  holderName String
  accountNo  String   @unique
  ifsc       String
  bankName   String
  panNumber  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("BankDetail")
}

model Otp {
  id          Int      @id @default(autoincrement())
  phone       String   @unique
  otp         String
  expiresAt   DateTime
  isVerified  Boolean  @default(false)
  resendCount Int      @default(0)
  lastSentAt  DateTime @default(now())

  @@map("Otp")
}

model SellerDocument {
  id               Int                @id @default(autoincrement())
  profileId        Int?
  sellerProfile    SellerProfile?     @relation(fields: [profileId], references: [id])
  type             SellerDocumentType
  url              String
  category         String?
  uploadedByUserId Int?
  name             String?
  size             BigInt             @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  uploadedByUser   User?              @relation("UploadedByUser", fields: [uploadedByUserId], references: [id])

  @@map("SellerDocument")
}

model Session {
  id               Int      @id @default(autoincrement())
  userId           Int
  userType         String
  jti              String   @unique
  refreshTokenHash String
  expiresAt        DateTime
  isRevoked        Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@map("sessions")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  resource  String
  ip        String?
  userAgent String?
  details   Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model SellerProfile {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  currentStep     Int       @default(0)
  status          String    @default("IN_PROGRESS")
  sessionId       Int       @unique @default(autoincrement())
  addressId       Int?
  sellerId        Int?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  approvedAt      DateTime?
  onHoldUntil     DateTime?
  rejectionReason String?

  reviews   SellerStepReview[]
  documents SellerDocument[]

  @@map("SellerProfile")
}

model SellerStepReview {
  id              Int       @id @default(autoincrement())
  sellerProfileId Int
  step            Int
  status          String    @default("PENDING")
  data            Json?
  remark          String?
  reviewedBy      String?
  reviewedAt      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@unique([sellerProfileId, step])
  @@map("SellerStepReview")
}

model Pincode {
  id        Int      @id @default(autoincrement())
  pincode   String   @unique
  state     String
  district  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Pincode")
}

model Language {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Language")
}

enum AdminStatus {
  PENDING_OTP
  PENDING_PROFILE
  PENDING_APPROVAL
  ACTIVE
  REJECTED
}

enum Role {
  buyer
  seller
  superadmin
  administrator
  operator
}

enum SellerDocumentType {
  PAN
  GST
  AADHAR
  BANK
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
}

enum ContactPrefix {
  Mr
  Mrs
  Miss
  Ms
}

enum MasterStatus {
  ACTIVE
  INACTIVE
}

enum BalanceType {
  Dr
  Cr
}

enum RegUnder {
  Micro
  Small
  Medium
}

enum RegType {
  Trading
  Service
  Manufacturing
}

enum CustomerType {
  industrial
  institutional
  dealer
  retailer
}

model AccountMaster {
  id Int @id @default(autoincrement())

  accountName String
  groupName   String[]

  gstNo String?
  panNo String

  addressLine1 String
  addressLine2 String?
  pincode      String
  area         String?
  subDistrict  String?
  district     String?
  state        String
  country      String?

  // Contact Persons
  prefix            ContactPrefix
  contactPersonName String
  emailId           String?
  mobileNo          String

  // Supplier Details
  supplierCode           String?  @unique
  supplierCreditDays     Int?
  supplierOpeningBalance Decimal?
  supplierBalanceType    BalanceType?

  // Customer Details
  customerCode           String?  @unique
  customerCreditDays     Int?
  customerOpeningBalance Decimal?
  customerBalanceType    BalanceType?
  customerType           CustomerType?

  // MSME Details
  msmeEnabled        Boolean @default(false)
  msmeId             String?
  regUnder           RegUnder?
  regType            RegType?
  msmeCertificateUrl String?

  otherDocuments Json?

  // Ownership
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  // Metadata
  status    MasterStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("account_master")
}

enum UnitStatus {
  ACTIVE
  INACTIVE
}

enum UnitSource {
  SYSTEM
  USER
}

model SystemUomLibrary {
  id                       Int      @id @default(autoincrement())
  full_name_of_measurement String
  unit_name                String
  uom_code                 String
  created_at               DateTime @default(now())

  @@map("system_uom_library")
}

model UnitMaster {
  id                       Int        @id @default(autoincrement())
  user_id                  Int
  unit_name                String
  gst_uom                  String
  full_name_of_measurement String
  source                   UnitSource @default(SYSTEM)
  status                   UnitStatus @default(ACTIVE)
  created_at               DateTime   @default(now())
  updated_at               DateTime   @updatedAt
  user                     User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  products                 Product[]

  @@unique([user_id, gst_uom])
  @@map("unit_master")
}


model Group {
  id          Int          @id @default(autoincrement())
  group_name  String
  parent_id   Int?
  userId      Int?
  is_header   Boolean      @default(false)
  status      MasterStatus @default(ACTIVE)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  parent      Group?       @relation("GroupToGroup", fields: [parent_id], references: [id])
  children    Group[]      @relation("GroupToGroup")
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  sub_groups  SubGroup[]

  @@map("groups")
}

model SubGroup {
  id             Int          @id @default(autoincrement())
  group_id       Int
  subgroup_name  String
  userId         Int?
  status         MasterStatus @default(ACTIVE)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  group          Group        @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sub_sub_groups SubSubGroup[]

  @@map("sub_groups")
}

model SubSubGroup {
  id               Int                   @id @default(autoincrement())
  sub_group_id     Int
  name             String
  userId           Int?
  status           MasterStatus          @default(ACTIVE)
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt

  sub_group        SubGroup              @relation(fields: [sub_group_id], references: [id], onDelete: Cascade)
  user             User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sub_sub_sub_groups SubSubSubGroup[]

  @@map("sub_sub_groups")
}

model SubSubSubGroup {
  id                 Int               @id @default(autoincrement())
  sub_sub_group_id   Int
  name               String
  userId             Int?
  status             MasterStatus      @default(ACTIVE)
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  sub_sub_group      SubSubGroup       @relation(fields: [sub_sub_group_id], references: [id], onDelete: Cascade)
  user               User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sub_sub_sub_sub_groups SubSubSubSubGroup[]

  @@map("sub_sub_sub_groups")
}

model SubSubSubSubGroup {
  id                   Int               @id @default(autoincrement())
  sub_sub_sub_group_id Int
  name                 String
  userId               Int?
  status               MasterStatus      @default(ACTIVE)
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  sub_sub_sub_group    SubSubSubGroup    @relation(fields: [sub_sub_sub_group_id], references: [id], onDelete: Cascade)
  user                 User?             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sub_sub_sub_sub_groups")
}


model Category {
  id          Int          @id @default(autoincrement())
  name        String
  user_id     Int
  status      MasterStatus @default(ACTIVE)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  user        User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sub_categories SubCategory[]
  products    Product[]

  @@unique([name, user_id])
  @@map("categories")
}

model SubCategory {
  id          Int          @id @default(autoincrement())
  name        String
  category_id Int
  user_id     Int
  status      MasterStatus @default(ACTIVE)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  category    Category     @relation(fields: [category_id], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([name, category_id, user_id])
  @@map("sub_categories")
}

model HsnMaster {
  id          Int      @id @default(autoincrement())
  hsn_code    String   @unique
  description String
  gst_rate    Decimal
  created_by  Int?
  created_at  DateTime @default(now())
  products    Product[]

  @@map("hsn_master")
}

enum ProductType {
  GOODS
  SERVICES
}

model Product {
  id              Int              @id @default(autoincrement())
  product_name    String
  product_code    String           
  uom_id          Int
  product_type    ProductType
  category_id     Int
  sub_category_id Int
  hsn_code        String
  tax_rate        Float
  description     String?
  status          MasterStatus     @default(ACTIVE)
  is_deleted      Boolean          @default(false)
  created_by      Int
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  uom             UnitMaster       @relation(fields: [uom_id], references: [id])
  category        Category         @relation(fields: [category_id], references: [id])
  sub_category    SubCategory      @relation(fields: [sub_category_id], references: [id])
  creator         User             @relation(fields: [created_by], references: [id])
  hsn             HsnMaster        @relation(fields: [hsn_code], references: [hsn_code])

  @@unique([product_code, created_by])
  @@map("products")
}
